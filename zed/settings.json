// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": "Material Icon Theme",
  "inlay_hints": {
    "enabled": false,
    "toggle_on_modifiers_press": {
      "alt": true,
    },
  },
  "buffer_font_size": 11.0,
  "buffer_font_family": "FiraCode Nerd Font Mono Retina",
  "context_servers": {
    "svelte": {
      "enabled": true,
      "command": "pnpx",
      "args": ["@sveltejs/mcp"],
    },
  },
  "agent_servers": {
    "OpenCode": {
      "command": "opencode",
      "args": ["acp"],
    },
  },
  "buffer_font_features": {
    "calt": true,
    "kern": true,
    "liga": true,
    "rlig": true,
  },
  "ui_font_size": 14,
  "ui_font_family": "FiraCode Nerd Font Mono Retina",
  "ui_font_fallbacks": [".SystemUIFont"],
  "terminal": {
    "font_size": 11.0,
    // "env": {
    //   "PATH": "${env:PATH}"
    // },
    "cursor_shape": "bar",
    "blinking": "on",
    "shell": {
      "program": "cmd.exe",
    },
    "font_family": "0xProto Nerd Font Mono",
  },
  "preview_tabs": {
    "enabled": false,
  },
  "git_panel": {
    "sort_by_path": false,
    "fallback_branch_name": "master",
  },
  "scroll_sensitivity": 2.0,
  "scroll_beyond_last_line": "one_page",
  "minimap": {
    "show": "always",
    "thumb": "always",
  },
  "hover_popover_delay": 50,
  "cursor_blink": true,
  "auto_indent_on_paste": true,
  "linked_edits": true,
  "show_whitespaces": "trailing",
  "show_edit_predictions": true,
  "ensure_final_newline_on_save": true,
  "tab_size": 2,
  "format_on_save": "on",
  "file_types": {
    "makefile": ["*.make"],
    "ignore": [".astylerc"],
    "JSON": [".prettierrc"],
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "theme": "Catppuccin Espresso (Blur)",
  "active_pane_modifiers": {
    "border_size": 0,
    "inactive_opacity": 0.8,
  },
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "title_bar": {
    "show_branch_icon": true,
    "show_user_menu": false,
    "show_onboarding_banner": false,
  },
  "tab_bar": {
    "show": false,
    "show_nav_history_buttons": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "status_bar": {
    "active_language_button": false,
    "cursor_position_button": false,
  },
  "project_panel": {
    "default_width": 300,
    "hide_root": true,
    "start_open": true,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "default_width": 300,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "small",
  },
  "scrollbar": {
    "show": "never",
  },
  "indent_guides": {
    "enabled": false,
  },
  "gutter": {
    "min_line_number_digits": 3,
    "folds": false,
    "runnables": false,
    "breakpoints": false,
  },
  "extend_comment_on_newline": false,
  "horizontal_scroll_margin": 15,
  "vertical_scroll_margin": 5,
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "launchpad",
  "inline_code_actions": false,
  "edit_predictions_disabled_in": ["comment"],
  "git": {
    "inline_blame": {
      "enabled": false,
    },
    "branch_picker": {
      "show_author_name": true,
    },
  },
  "agent": {
    "single_file_review": true,
    "default_model": {
      "provider": "zai-org",
      "model": "glm-4.7-flash",
    },
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "terminal": {
          "always_allow": [
            { "pattern": "^cargo\\s+(build|test|check|fmt|clippy)" },
            { "pattern": "^pnpm\\s+(build|test|check|format|lint)" },
            { "pattern": "^git\\s+(status|log|diff)" },
          ],
          "always_deny": [{ "pattern": "rm\\s+-rf\\s+(/|~)" }],
          "always_confirm": [{ "pattern": "sudo\\s" }],
        },
        "edit_file": {
          "always_deny": [
            { "pattern": "\\.env" },
            { "pattern": "\\.(pem|key)$" },
          ],
        },
      },
    },
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "prettier": {
    "allowed": true,
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
      },
    },
  },
  "theme_overrides": {
    "Catppuccin Espresso (Blur)": {
      "syntax": {
        "constant.comment.todo": {
          "color": "#ffffff",
          "background_color": "#4078f2ff",
          "font_weight": 700,
        },
        "string.comment.info": {
          "color": "#ffffff",
          "background_color": "#50a14fff",
          "font_weight": 700,
        },
        "keyword.comment.warn": {
          "color": "#ffffff",
          "background_color": "#c18401ff",
          "font_weight": 700,
        },
        "property.comment.error": {
          "color": "#ffffff",
          "background_color": "#ca1243ff",
          "font_weight": 700,
        },
        "emphasis.comment.user": {
          "color": "#ffffff",
          "background_color": "#000000dd",
          "font_weight": 700,
        },
      },
    },
  },
  "theme_overrides": {
    "Catppuccin Espresso (Blur)": {},
  },
  "language_models": {
    "openai_compatible": {
      "Uranus": {
        "api_url": "http://uranus:1234/v1",
        "available_models": [
          {
            "name": "openai/gpt-oss-20b",
            "display_name": "GPT-20B",
            "max_tokens": 131072,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
            },
          },
        ],
      },
    },
  },
  "status_bar": {
    "line_endings_button": true,
  },
  "languages": {
    "Rust": {
      "format_on_save": "on",
      "formatter": "language_server",
    },
  },
  "format_on_save": "on",
  "profiles": {
    "minimal": {
      "status_bar": {
        "experimental.show": false,
      },
      "minimap": {
        "show": "never",
      },
      "title_bar": {
        "show_branch_name": false,
        "show_project_items": false,
      },
    },
  },
}
